# Build context: repository root
# podman build -f packages/coding-agent/Containerfile -t pi-agent .

# ==============================================================================
# Stage 1: Extract package manifests (keeps npm ci cacheable without a manual list)
# ==============================================================================
FROM busybox AS manifests
WORKDIR /src
COPY . .
RUN find . -not \( -name "package.json" -o -name "package-lock.json" -o -type d \) -delete 2>/dev/null; \
    find . -empty -type d -delete 2>/dev/null; \
    true

# ==============================================================================
# Stage 2: Builder
# ==============================================================================
FROM node:22-bookworm-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY --from=manifests /src/ .

RUN npm ci

# Copy source (layer invalidated on code changes, deps layer above stays cached)
COPY . .

# Build only the 4 packages needed by coding-agent, in dependency order.
# pi-ai uses `npx tsgo` directly instead of `npm run build` to skip
# generate-models, which needs network. models.generated.ts is committed.
RUN cd packages/tui && npm run build \
    && cd ../ai && npx tsgo -p tsconfig.build.json \
    && cd ../agent && npm run build \
    && cd ../coding-agent && npm run build

# ==============================================================================
# Stage 3: Runtime
# ==============================================================================
FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ripgrep \
    fd-find \
    procps \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/fdfind /usr/bin/fd

WORKDIR /app

COPY --from=manifests /src/ .

RUN npm ci --omit=dev --ignore-scripts

# Copy built artifacts from builder
COPY --from=builder /build/packages/tui/dist packages/tui/dist
COPY --from=builder /build/packages/ai/dist packages/ai/dist
COPY --from=builder /build/packages/agent/dist packages/agent/dist
COPY --from=builder /build/packages/coding-agent/dist packages/coding-agent/dist

# Runtime assets (skills, help text, examples)
COPY packages/coding-agent/docs packages/coding-agent/docs
COPY packages/coding-agent/examples packages/coding-agent/examples
COPY packages/coding-agent/README.md packages/coding-agent/
COPY packages/coding-agent/CHANGELOG.md packages/coding-agent/

RUN ln -s /app/packages/coding-agent/dist/cli.js /usr/local/bin/pi

RUN chown -R node:node /app

USER node

ENV TERM=xterm-256color
ENV PI_SKIP_VERSION_CHECK=1
ENV NODE_ENV=production
ENV NPM_CONFIG_PREFIX=/home/node/.npm-global

# pgrep is in procps, which is added above
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD pgrep -f "/app/packages/coding-agent/dist/cli.js" > /dev/null || exit 1

WORKDIR /home/node/workspace

ENTRYPOINT ["node", "/app/packages/coding-agent/dist/cli.js"]
