# Build context: repository root
# podman build -f packages/coding-agent/Containerfile -t pi-agent .

# ==============================================================================
# Stage 1: Builder
# ==============================================================================
FROM node:22-bookworm-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy package manifests first for layer caching
COPY package.json package-lock.json ./
COPY packages/tui/package.json packages/tui/
COPY packages/ai/package.json packages/ai/
COPY packages/agent/package.json packages/agent/
COPY packages/coding-agent/package.json packages/coding-agent/
COPY packages/mom/package.json packages/mom/
COPY packages/web-ui/package.json packages/web-ui/
COPY packages/pods/package.json packages/pods/
COPY packages/web-ui/example/package.json packages/web-ui/example/
COPY packages/coding-agent/examples/extensions/with-deps/package.json packages/coding-agent/examples/extensions/with-deps/
COPY packages/coding-agent/examples/extensions/custom-provider-anthropic/package.json packages/coding-agent/examples/extensions/custom-provider-anthropic/
COPY packages/coding-agent/examples/extensions/custom-provider-gitlab-duo/package.json packages/coding-agent/examples/extensions/custom-provider-gitlab-duo/
COPY packages/coding-agent/examples/extensions/custom-provider-qwen-cli/package.json packages/coding-agent/examples/extensions/custom-provider-qwen-cli/

RUN npm ci

# Copy source (layer invalidated on code changes, deps layer above stays cached)
COPY . .

# Build only the 4 packages needed by coding-agent, in dependency order.
# Skip generate-models for pi-ai — models.generated.ts is committed to source.
RUN cd packages/tui && npx tsgo -p tsconfig.build.json \
    && cd ../ai && npx tsgo -p tsconfig.build.json \
    && cd ../agent && npx tsgo -p tsconfig.build.json \
    && cd ../coding-agent && npm run build

# ==============================================================================
# Stage 2: Runtime
# ==============================================================================
FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ripgrep \
    fd-find \
    procps \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/fdfind /usr/bin/fd

WORKDIR /app

# Copy package manifests and lockfile for production install
COPY package.json package-lock.json ./
COPY packages/tui/package.json packages/tui/
COPY packages/ai/package.json packages/ai/
COPY packages/agent/package.json packages/agent/
COPY packages/coding-agent/package.json packages/coding-agent/
COPY packages/mom/package.json packages/mom/
COPY packages/web-ui/package.json packages/web-ui/
COPY packages/pods/package.json packages/pods/
COPY packages/web-ui/example/package.json packages/web-ui/example/
COPY packages/coding-agent/examples/extensions/with-deps/package.json packages/coding-agent/examples/extensions/with-deps/
COPY packages/coding-agent/examples/extensions/custom-provider-anthropic/package.json packages/coding-agent/examples/extensions/custom-provider-anthropic/
COPY packages/coding-agent/examples/extensions/custom-provider-gitlab-duo/package.json packages/coding-agent/examples/extensions/custom-provider-gitlab-duo/
COPY packages/coding-agent/examples/extensions/custom-provider-qwen-cli/package.json packages/coding-agent/examples/extensions/custom-provider-qwen-cli/

RUN npm ci --omit=dev --ignore-scripts

# Copy built artifacts from builder
COPY --from=builder /build/packages/tui/dist packages/tui/dist
COPY --from=builder /build/packages/ai/dist packages/ai/dist
COPY --from=builder /build/packages/agent/dist packages/agent/dist
COPY --from=builder /build/packages/coding-agent/dist packages/coding-agent/dist

# Runtime assets (skills, help text, examples)
COPY packages/coding-agent/docs packages/coding-agent/docs
COPY packages/coding-agent/examples packages/coding-agent/examples
COPY packages/coding-agent/README.md packages/coding-agent/
COPY packages/coding-agent/CHANGELOG.md packages/coding-agent/

RUN ln -s /app/packages/coding-agent/dist/cli.js /usr/local/bin/pi

# Add a non-root user for security. The home directory is set to /workspace.
RUN groupadd --gid 1001 agent \
    && useradd --uid 1001 --gid 1001 --shell /bin/bash --create-home --home-dir /workspace agent \
    && chown -R agent:agent /app

USER agent

ENV TERM=xterm-256color
ENV PI_SKIP_VERSION_CHECK=1
ENV NODE_ENV=production

# pgrep is in procps, which is added above
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD pgrep -f "/app/packages/coding-agent/dist/cli.js" > /dev/null || exit 1

WORKDIR /workspace

ENTRYPOINT ["node", "/app/packages/coding-agent/dist/cli.js"]
